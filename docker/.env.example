# Пример переменных для docker-compose (при необходимости).
# Скопировать в .env в корне проекта.

# Фронт — URL n8n для браузера (localhost, т.к. запросы с клиента)
NEXT_PUBLIC_N8N_WEBHOOK_URL=http://localhost:5678

# n8n — БД PostgreSQL (по умолчанию: user n8n, db n8n, password n8n)
# N8N_DB_USER=n8n
# N8N_DB_PASSWORD=n8n
# N8N_DB_NAME=n8n

# Для Supabase (после supabase start, см. docker/README.md):
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<из supabase status>
